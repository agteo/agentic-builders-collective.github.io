---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Agentic Builders Collective" } = Astro.props;

const footerLinks = [
  { href: "/", label: "home" },
  { href: "/people/", label: "people" },
  { href: "/resources/", label: "links" },
  { href: "/shares/", label: "shares" },
  { href: "/meetups/", label: "meetups" },
  { href: "/tips/", label: "tips" }
];

const isCurrent = (href: string) => {
  if (href === "/") {
    return Astro.url.pathname === "/";
  }

  return Astro.url.pathname.startsWith(href);
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0A0D1C" />
    <meta name="apple-mobile-web-app-title" content="ABC" />
    <meta name="mobile-web-app-capable" content="yes" />
    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-top-menu" aria-label="Primary">
      <div class="site-top-links">
        {
          footerLinks.map((item) => (
            <a href={item.href} class:list={{ current: isCurrent(item.href) }}>
              {item.label}
            </a>
          ))
        }
      </div>
    </nav>

    <div class="shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-prompt">&gt;</span>
          <span class="brand-mark" data-logo-cycle>ABC</span>
          <span class="brand-cursor">_</span>
        </a>
      </header>

      <main class="page">
        <slot />
      </main>

      <footer class="site-footer">
        <a class="footer-email" href="mailto:hello@agenticbuilders.sg">
          <span class="footer-email-user">hello</span><span class="footer-email-at">@</span><span class="footer-email-host">agenticbuilders.sg</span>
        </a>
      </footer>
    </div>

    <script>
      import "../scripts/logo-gradient";
    </script>
  </body>
</html>
