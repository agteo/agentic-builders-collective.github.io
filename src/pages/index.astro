---
/** Scales base timings (0.8 then ×0.75 ≈ another 25% faster). */
const SPEED = 0.6;
/** Seconds between each block (glyph) reveal; tuned so ASCII + rule + tagline land in ~5–10s. */
const GLYPH_GAP_SEC = 0.041 * SPEED;
/** Extra pause after each ASCII row before the next line begins. */
const LINE_PAUSE_SEC = 0.13 * SPEED;
const RULE_DRAW_SEC = 0.55 * SPEED;
const AFTER_ASCII_PAUSE_SEC = 0.14 * SPEED;
const AFTER_RULE_PAUSE_SEC = 0.38 * SPEED;
const GLYPH_ANIM_SEC = 0.38 * SPEED;
/** Tagline reveal: 1.5× = 50% slower than ASCII cadence. */
const TAGLINE_SLOW_MULT = 1.5;
const TAGLINE_GLYPH_GAP_SEC = GLYPH_GAP_SEC * TAGLINE_SLOW_MULT;
const TAGLINE_GLYPH_ANIM_SEC = GLYPH_ANIM_SEC * TAGLINE_SLOW_MULT;
const COLOUR_SPAN_PATTERN = /<span style="color:(#[0-9a-f]{6})">([^<]*)<\/span>/gi;
const DIM_COLOUR_THRESHOLD = 140;

function injectGlyphsSequential(
  html: string,
  startSec: number,
  gapSec: number = GLYPH_GAP_SEC
): { html: string; cursorSec: number } {
  let t = startSec;
  const out = html.replace(/<span style="([^"]*)"/g, (_, styles) => {
    const delay = t;
    t += gapSec;
    return `<span class="logo-glyph" style="${styles};--logo-del:${delay.toFixed(3)}s"`;
  });
  return { html: out, cursorSec: t };
}

function wrapAsciiLineByLine(html: string): { html: string; asciiEndSec: number } {
  /** trimEnd only: export HTML keeps a leading space on row 1; full trim() strips it and misaligns the grid. */
  const lines = html.replace(/\r\n/g, "\n").trimEnd().split("\n");
  let cursor = 0;
  const parts = lines.map((line, idx) => {
    const { html: inner, cursorSec } = injectGlyphsSequential(line, cursor, GLYPH_GAP_SEC);
    cursor = cursorSec;
    if (idx < lines.length - 1) cursor += LINE_PAUSE_SEC;
    return `<div class="ascii-line">${inner}</div>`;
  });
  return { html: parts.join(""), asciiEndSec: cursor };
}

function getColourBrightness(hex: string): number {
  const value = Number.parseInt(hex.slice(1), 16);
  const red = (value >> 16) & 255;
  const green = (value >> 8) & 255;
  const blue = value & 255;
  return (red + green + blue) / 3;
}

function decorateAsciiHtml(html: string): string {
  const lines = html.replace(/\r\n/g, "\n").trimEnd().split("\n");
  const totalRows = Math.max(lines.length - 1, 1);

  return lines
    .map((line, rowIndex) => {
      const t = rowIndex / totalRows;

      return line.replace(COLOUR_SPAN_PATTERN, (_, colour: string, char: string) => {
        const isDim = getColourBrightness(colour) < DIM_COLOUR_THRESHOLD;
        const cycleAttribute = char.trim() ? " data-logo-cycle" : "";
        return `<span style="color:${colour}" data-logo-t="${t.toFixed(4)}" data-logo-dim="${isDim}"${cycleAttribute}>${char}</span>`;
      });
    })
    .join("\n");
}

function decorateTaglineHtml(html: string): string {
  const spanCount = [...html.matchAll(COLOUR_SPAN_PATTERN)].length;
  const totalGlyphs = Math.max(spanCount - 1, 1);
  let glyphIndex = 0;

  return html.replace(COLOUR_SPAN_PATTERN, (_, colour: string, char: string) => {
    const t = glyphIndex / totalGlyphs;
    glyphIndex += 1;
    return `<span style="color:${colour}" data-logo-t="${t.toFixed(4)}" data-logo-cycle>${char}</span>`;
  });
}

const asciiHtml = ` <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span>  <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span><span style="color:#5a5e65"> </span>  <span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#e0eafc">█</span><span style="color:#5a5e65">╗</span>
