<span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">║</span> <span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">╔</span><span style="color:#575c63">╝</span> <span style="color:#d9e5f8">█</span><span style="color:#d9e5f8">█</span><span style="color:#575c63">║</span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span><span style="color:#575c63"> </span>
<span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╔</span><span style="color:#565b63">═</span><span style="color:#565b63">═</span><span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">║</span> <span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╔</span><span style="color:#565b63">═</span><span style="color:#565b63">═</span><span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">╗</span> <span style="color:#d6e3f7">█</span><span style="color:#d6e3f7">█</span><span style="color:#565b63">║</span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span><span style="color:#565b63"> </span>
<span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">║</span><span style="color:#d2e0f5"> </span><span style="color:#d2e0f5"> </span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">║</span> <span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">╔</span><span style="color:#545a62">╝</span> <span style="color:#545a62">╚</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#d2e0f5">█</span><span style="color:#545a62">╗</span>
<span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">╝</span><span style="color:#535961"> </span><span style="color:#535961"> </span><span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">╝</span> <span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">╝</span><span style="color:#535961"> </span> <span style="color:#535961"> </span><span style="color:#535961">╚</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">═</span><span style="color:#535961">╝</span>`;

const taglineHtml = `<span style="color:#e0eafc">a</span><span style="color:#dfeafc">g</span><span style="color:#dfe9fb">e</span><span style="color:#dee9fb">n</span><span style="color:#dde8fb">t</span><span style="color:#dde8fa">i</span><span style="color:#dce7fa">c</span> <span style="color:#dbe6f9">b</span><span style="color:#dae6f9">u</span><span style="color:#d9e5f9">i</span><span style="color:#d9e5f8">l</span><span style="color:#d8e4f8">d</span><span style="color:#d8e4f8">e</span><span style="color:#d7e4f7">r</span><span style="color:#d6e3f7">s</span> <span style="color:#d5e2f6">c</span><span style="color:#d4e2f6">o</span><span style="color:#d4e1f5">l</span><span style="color:#d3e1f5">l</span><span style="color:#d2e0f5">e</span><span style="color:#d2e0f4">c</span><span style="color:#d1dff4">t</span><span style="color:#d0dff4">i</span><span style="color:#d0def3">v</span><span style="color:#cfdef3">e</span>`;

const { html: asciiAnimatedHtml, asciiEndSec } = wrapAsciiLineByLine(decorateAsciiHtml(asciiHtml));

const ruleRevealDelaySec = asciiEndSec + AFTER_ASCII_PAUSE_SEC;
const taglineStartSec = ruleRevealDelaySec + RULE_DRAW_SEC + AFTER_RULE_PAUSE_SEC;

const { html: taglineAnimatedHtml, cursorSec: taglineEndSec } = injectGlyphsSequential(
  decorateTaglineHtml(taglineHtml),
  taglineStartSec,
  TAGLINE_GLYPH_GAP_SEC
);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>abc</title>
    <style
      define:vars={{
        glyphAnimSec: `${GLYPH_ANIM_SEC.toFixed(3)}s`,
        taglineGlyphAnimSec: `${TAGLINE_GLYPH_ANIM_SEC.toFixed(3)}s`,
        ruleDurFallback: `${RULE_DRAW_SEC.toFixed(3)}s`,
        contactFadeDelaySec: `${taglineEndSec.toFixed(3)}s`
      }}
    >
      @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700;800&family=Space+Mono:wght@400;700&display=swap');

      :root {
        --logo-reveal-speed: 1;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: #000000;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        font-family: 'JetBrains Mono', 'Courier New', monospace;
      }

      .logo {
        text-align: center;
        padding: 72px;
      }

      .ascii {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 26px;
        line-height: 1.25;
        font-weight: 800;
        margin-bottom: 8px;
        display: inline-block;
        transform: skewX(-18deg);
      }

      /*
       * Injected markup from set:html has no data-astro-cid; scoped selectors would not match.
       */
      :global(.ascii-line) {
        display: block;
        white-space: pre;
      }

      :global(.logo-glyph) {
        display: inline;
        opacity: 0;
        animation: logoGlyphIn calc(var(--glyphAnimSec) * var(--logo-reveal-speed)) cubic-bezier(0.22, 1, 0.36, 1)
          forwards;
        animation-delay: calc(var(--logo-del, 0s) * var(--logo-reveal-speed));
      }

      @keyframes logoGlyphIn {
        from {
          opacity: 0;
          transform: translateY(0.22em) scale(0.82);
          filter: blur(4px);
        }
        to {
          opacity: 1;
          transform: translateY(0) scale(1);
          filter: blur(0);
        }
      }

      .rule {
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 26px;
        white-space: pre;
        margin-bottom: 8px;
      }

      .logo-rule {
        opacity: 0;
        clip-path: inset(0 100% 0 0);
        animation: logoRuleIn calc(var(--logo-rule-dur, var(--ruleDurFallback)) * var(--logo-reveal-speed)) ease forwards;
        animation-delay: calc(var(--logo-del, 0s) * var(--logo-reveal-speed));
      }

      @keyframes logoRuleIn {
        to {
          opacity: 0.4;
          clip-path: inset(0 0 0 0);
        }
      }

      .tagline {
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 20px;
        font-weight: 400;
        letter-spacing: 4px;
        word-spacing: 8px;
        text-transform: none;
        white-space: nowrap;
        line-height: 1.6;
      }

      .contact-link {
        align-items: center;
        animation: contactFadeIn 0.5s ease forwards;
        animation-delay: calc(var(--contactFadeDelaySec) * var(--logo-reveal-speed, 1));
        bottom: 28px;
        display: inline-flex;
        font-family: 'Space Mono', 'Courier New', monospace;
        font-size: 15px;
        left: 50%;
        letter-spacing: 0.08em;
        opacity: 0;
        position: fixed;
        text-decoration: none;
        transform: translateX(-50%);
        white-space: nowrap;
      }

      .calendar-link {
        bottom: 64px;
      }

      .contact-link-icon {
        color: #777;
        display: inline-block;
        font-size: 2em;
        line-height: 1;
        margin-right: 10px;
        transform: translateY(-3px);
      }

      .contact-link-greeting {
        color: var(--logo-gradient-start, #e0eafc);
      }

      .contact-link-at {
        color: #777;
      }

      .contact-link-host {
        color: rgba(224, 234, 252, 0.88);
      }

      .contact-link:hover,
      .contact-link:focus-visible {
        outline: none;
      }

      @keyframes contactFadeIn {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      .tagline :global(.logo-glyph) {
        animation-duration: calc(var(--taglineGlyphAnimSec) * var(--logo-reveal-speed));
      }

      /* ── Mobile: keep logo within 90vw (5% margin each side) ── */
      @media (max-width: 480px) {
        .logo {
          padding: 40px 5%;
        }

        .ascii {
          font-size: min(26px, 5vw);
        }

        .rule {
          font-size: min(26px, 5vw);
        }

        .tagline {
          font-size: min(20px, 4vw);
          letter-spacing: max(1px, 0.8vw);
          word-spacing: max(2px, 1.6vw);
        }

        .contact-link {
          font-size: min(15px, 3.5vw);
        }

        .calendar-link {
          bottom: 54px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        :global(.logo-glyph) {
          animation: none !important;
          opacity: 1 !important;
          transform: none !important;
          filter: none !important;
        }

        .logo-rule {
          animation: none !important;
          opacity: 0.4 !important;
          clip-path: none !important;
        }

        .contact-link {
          animation: none !important;
          opacity: 1 !important;
        }
      }
    </style>
  </head>
  <body>
    <div class="logo" data-logo-reanimate data-logo-reveal-duration={taglineEndSec.toFixed(3)}>
      <div class="ascii" set:html={asciiAnimatedHtml}></div>
      <div
        class="rule logo-rule"
        data-logo-cycle
        data-logo-rule
        style={`color:#d8e4f8;--logo-del:${ruleRevealDelaySec.toFixed(3)}s;--logo-rule-dur:${RULE_DRAW_SEC}s`}
      >
        ┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄┄
      </div>
      <div class="tagline" set:html={taglineAnimatedHtml}></div>
    </div>

    <a class="contact-link calendar-link" href="/meetups/">
      <span class="contact-link-greeting">events</span><span class="contact-link-at">@</span><span class="contact-link-host">/meetups/</span>
    </a>

    <a class="contact-link" href="mailto:hello@agenticbuilders.sg">
      <span class="contact-link-icon" aria-hidden="true">✉</span>
      <span class="contact-link-greeting">hello</span><span class="contact-link-at">@</span><span class="contact-link-host">agenticbuilders.sg</span>
    </a>

    <script>
      (function () {
        const STORAGE_KEY = "abc-logo-reveal-seen";
        const FAST_SPEED_MULTIPLIER = 0.4;
        const root = document.documentElement;

        function getRevealDurationMs() {
          const logo = document.querySelector("[data-logo-reveal-duration]");
          const value = logo?.dataset.logoRevealDuration;
          const parsed = Number.parseFloat(value ?? "");
          if (!Number.isFinite(parsed)) {
            return 12000;
          }
          return Math.max(parsed * 1000, 900);
        }

        function setRevealSpeed(speed) {
          root.style.setProperty("--logo-reveal-speed", String(speed));
        }

        let hasSeen = false;
        try {
          hasSeen = window.localStorage.getItem(STORAGE_KEY) === "true";
        } catch {}

        if (hasSeen) {
          setRevealSpeed(FAST_SPEED_MULTIPLIER);
        } else {
          setRevealSpeed(1);
          try {
            window.localStorage.setItem(STORAGE_KEY, "true");
          } catch {}

          window.setTimeout(() => {
            setRevealSpeed(FAST_SPEED_MULTIPLIER);
          }, getRevealDurationMs());
        }
      })();
    </script>

    <script>
      import "../scripts/logo-gradient";
    </script>
  </body>
</html>
