---
import BaseLayout from "../../layouts/BaseLayout.astro";

const whatsappUrl = "https://chat.whatsapp.com/Be8X9lVJQET4JfkKMW5Qxn";
---

<BaseLayout title="Contact — ABC">
  <h1 class="page-title">Contact</h1>

  <section>
    <h3 class="section-label">Get In Touch</h3>
    <div class="card">
      <p>Want to speak at a meetup, sponsor an event, partner with us, or just say hello? Reach out to us directly — put our email (the one at the bottom!).</p>
    </div>
  </section>

  <section>
    <h3 class="section-label">Other Ways to Connect</h3>
    <div class="list">
      <div class="list-item">
        <a class="list-item-title" href={whatsappUrl} target="_blank" rel="noopener">WhatsApp Group Chat</a>
        <p>The main hub — daily tips, tool news, troubleshooting, and project sharing.</p>
      </div>
    </div>
  </section>
</BaseLayout>
