---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { contributionLinks } from "../../lib/contribution-links";
import { buildEventIndex, buildPeopleIndex, getLinkedEvent, resolvePersonRefs } from "../../lib/relations";

const allMembers = await getCollection("members");
const organisers = await getCollection("organisers");
const allArticles = await getCollection("articles");
const allProjects = await getCollection("projects");
const allPresentations = await getCollection("presentations");
const allEvents = await getCollection("events");
const peopleById = buildPeopleIndex([...organisers, ...allMembers]);
const eventsById = buildEventIndex(allEvents);

const orgNames = new Set(organisers.map((o) => o.data.name));
const members = allMembers
  .filter((person) => !orgNames.has(person.data.name))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) {
      return a.data.featured ? -1 : 1;
    }

    return a.data.name.localeCompare(b.data.name);
  });

type BackrefGroup = {
  label: string;
  items: {
    href: string;
    title: string;
  }[];
};

const backrefsByPersonId = new Map<string, Map<string, BackrefGroup["items"]>>();
const backrefLabels = new Map([
  ["articles", "articles"],
  ["projects", "projects"],
  ["presentations", "presentations"],
  ["events", "events"],
]);

const addBackref = (personId: string, group: string, href: string, title: string) => {
  if (!backrefsByPersonId.has(personId)) {
    backrefsByPersonId.set(personId, new Map());
  }

  const personBackrefs = backrefsByPersonId.get(personId)!;
  if (!personBackrefs.has(group)) {
    personBackrefs.set(group, []);
  }

  const groupItems = personBackrefs.get(group)!;
  if (!groupItems.some((item) => item.href === href)) {
    groupItems.push({ href, title });
  }
};

for (const article of allArticles) {
  resolvePersonRefs(article.data.authors, peopleById, `article "${article.data.id}" authors`);
  for (const author of article.data.authors) {
    if (author.personId) {
      addBackref(author.personId, "articles", `/articles/#${article.data.id}`, article.data.title);
    }
  }
}

for (const project of allProjects) {
  resolvePersonRefs(project.data.makers, peopleById, `project "${project.id}" makers`);
  for (const maker of project.data.makers) {
    if (maker.personId) {
      addBackref(maker.personId, "projects", `/showcase/#${project.id}`, project.data.title);
    }
  }
}

for (const presentation of allPresentations) {
  const event = getLinkedEvent(presentation.data.eventId, eventsById, `presentation "${presentation.data.id}"`);
  resolvePersonRefs(presentation.data.speakers, peopleById, `presentation "${presentation.data.id}" speakers`);

  for (const speaker of presentation.data.speakers) {
    if (speaker.personId) {
      addBackref(speaker.personId, "presentations", `/showcase/#${presentation.data.id}`, presentation.data.title);
      addBackref(speaker.personId, "events", `/events/#${event.id}`, event.data.title);
    }
  }
}

for (const event of allEvents) {
  resolvePersonRefs(event.data.hosts, peopleById, `event "${event.id}" hosts`);
  resolvePersonRefs(event.data.speakers, peopleById, `event "${event.id}" speakers`);

  for (const host of event.data.hosts) {
    if (typeof host !== "string" && host.personId) {
      addBackref(host.personId, "events", `/events/#${event.id}`, event.data.title);
    }
  }

  for (const speaker of event.data.speakers) {
    if (typeof speaker !== "string" && speaker.personId) {
      addBackref(speaker.personId, "events", `/events/#${event.id}`, event.data.title);
    }
  }
}

const getBackrefGroups = (personId: string): BackrefGroup[] => {
  const personBackrefs = backrefsByPersonId.get(personId);
  if (!personBackrefs) return [];

  return Array.from(backrefLabels.entries()).flatMap(([key, label]) => {
    const items = personBackrefs.get(key) ?? [];
    return items.length > 0 ? [{ label, items }] : [];
  });
};
const membersJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Agentic Builders Collective Members",
  itemListElement: [...organisers, ...members].map((person, index) => ({
    "@type": "ListItem",
    position: index + 1,
    item: {
      "@type": "Person",
      name: person.data.name,
      url: `https://www.agenticbuilders.sg/community/#${person.data.id}`,
      jobTitle: "role" in person.data ? person.data.role : "Member",
      worksFor: person.data.company ? { "@type": "Organization", name: person.data.company } : undefined,
      sameAs: [person.data.website, person.data.linkedin, person.data.github].filter(Boolean),
      description: person.data.tagline || undefined,
    },
  })),
};
---

<BaseLayout
  title="community"
  description="Meet the organisers behind Agentic Builders Collective and explore the Singapore community building with AI coding tools."
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify(membersJsonLd)} />
  <h1 class="page-title">Community</h1>

  <section>
    <h3 class="section-label">Organisers</h3>
    <div class="grid columns-2">
      {organisers.map((person) => (
        <div class="person-card" id={person.data.id}>
          <div class="person-card-header">
            <span class="person-card-title">{person.data.name}</span>
            <div class="person-card-meta">
              <span>{person.data.role}</span>
              {person.data.company && (
                <span class="company-span">
                  {person.data.companyUrl ? (
                    <a href={person.data.companyUrl} target="_blank" rel="noopener" class="muted-link">{person.data.company}</a>
                  ) : (
                    person.data.company
                  )}
                </span>
              )}
            </div>
          </div>
          {person.data.tagline && <p class="person-card-tagline">{person.data.tagline}</p>}
          <div class="person-card-links">
            {person.data.website && (
              <a class="muted-link" href={person.data.website} target="_blank" rel="noopener">Website</a>
            )}
            {person.data.linkedin && (
              <a class="muted-link" href={person.data.linkedin} target="_blank" rel="noopener">LinkedIn</a>
            )}
            {person.data.github && (
              <a class="muted-link" href={person.data.github} target="_blank" rel="noopener">GitHub</a>
            )}
          </div>
          {(() => {
            const backrefGroups = getBackrefGroups(person.data.id);
            return backrefGroups.length > 0 && (
              <div class="person-card-backrefs">
                {backrefGroups.map((group) => (
                  <div class="person-card-backref-group">
                    <span class="person-card-backref-label">{group.label}</span>
                    {group.items.map((item, index) => (
                      <a class="person-card-backref-link" href={item.href} title={item.title}>[{index + 1}]</a>
                    ))}
                  </div>
                ))}
              </div>
            );
          })()}
        </div>
      ))}
    </div>
  </section>

  <section>
    <h3 class="section-label">Members</h3>
    {members.length > 0 ? (
      <div class="grid columns-2">
        {members.map((person) => (
          <div class="person-card" id={person.data.id}>
            <div class="person-card-header">
              <span class="person-card-title">{person.data.name}</span>
              {(person.data.company || person.data.featured) && (
                <div class="person-card-meta">
                  {person.data.company && <span>{person.data.company}</span>}
                  {person.data.featured && <span>Featured</span>}
                </div>
              )}
            </div>
            {person.data.tagline && <p class="person-card-tagline">{person.data.tagline}</p>}
            <div class="person-card-links">
              {person.data.website && (
                <a class="muted-link" href={person.data.website} target="_blank" rel="noopener">Website</a>
              )}
              {person.data.linkedin && (
                <a class="muted-link" href={person.data.linkedin} target="_blank" rel="noopener">LinkedIn</a>
              )}
              {person.data.github && (
                <a class="muted-link" href={person.data.github} target="_blank" rel="noopener">GitHub</a>
              )}
            </div>
            {(() => {
              const backrefGroups = getBackrefGroups(person.data.id);
              return backrefGroups.length > 0 && (
                <div class="person-card-backrefs">
                  {backrefGroups.map((group) => (
                    <div class="person-card-backref-group">
                      <span class="person-card-backref-label">{group.label}</span>
                      {group.items.map((item, index) => (
                        <a class="person-card-backref-link" href={item.href} title={item.title}>[{index + 1}]</a>
                      ))}
                    </div>
                  ))}
                </div>
              );
            })()}
          </div>
        ))}
      </div>
    ) : (
      <p>No members listed yet. <a class="muted-link" href={contributionLinks.person} target="_blank" rel="noopener">Add a person by submitting a pull request</a></p>
    )}
  </section>
</BaseLayout>

<style>
  .person-card-backrefs {
    color: var(--muted);
    display: grid;
    font-size: 1rem;
    gap: 4px;
    opacity: 0.85;
  }

  .person-card-backref-group {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .person-card-backref-label {
    color: var(--muted);
  }

  .person-card-backref-link {
    color: var(--accent);
    font-size: 1rem;
    text-decoration: none;
  }

  .person-card-backref-link:hover,
  .person-card-backref-link:focus-visible {
    text-decoration: underline;
  }
</style>
