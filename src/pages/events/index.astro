---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allEvents = await getCollection("events");
const now = new Date();
const formatTime = (time: string) => time.replace(/\s*SGT$/, "");

const upcoming = allEvents
  .filter((e) => e.data.status === "upcoming" || new Date(e.data.date) >= now)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = allEvents
  .filter((e) => e.data.status === "past" && new Date(e.data.date) < now)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const pastMeetups = past.filter((event) => event.data.kind !== "learning");
const pastLearning = past.filter((event) => event.data.kind === "learning");
---

<BaseLayout title="Events — ABC">
  <style>
    .events-muted-link::after {
      content: none;
    }

    .events-register {
      justify-self: start;
    }
  </style>

  <h1 class="page-title">Events</h1>

  <section>
    <h3 class="section-label">Upcoming</h3>
    {upcoming.length === 0 ? (
      <div class="card">
        <p>No upcoming events — <a href="https://chat.whatsapp.com/Be8X9lVJQET4JfkKMW5Qxn" target="_blank" rel="noopener" style="color:var(--accent);">join the WhatsApp chat</a> for announcements.</p>
      </div>
    ) : (
      <div class="list">
        {upcoming.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { weekday: "short", year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
            {event.data.registrationUrl && (
              <a class="button button-primary events-register" href={event.data.registrationUrl} target="_blank" rel="noopener">Register <span class="inline-arrow" aria-hidden="true">▶</span></a>
            )}
          </div>
        ))}
      </div>
    )}
  </section>

  <section>
    <h3 class="section-label">Meetups</h3>
    {pastMeetups.length === 0 ? (
      <p>No past events yet.</p>
    ) : (
      <div class="list">
        {pastMeetups.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>

  <section>
    <h3 class="section-label">Learning</h3>
    {pastLearning.length === 0 ? (
      <p>No learning sessions yet.</p>
    ) : (
      <div class="list">
        {pastLearning.map((event) => (
          <div class="list-item" id={event.id}>
            <div class="list-item-header">
              {event.data.registrationUrl ? (
                <a class="list-item-title" href={event.data.registrationUrl} target="_blank" rel="noopener">{event.data.title}</a>
              ) : (
                <span class="list-item-title">{event.data.title}</span>
              )}
              <div class="card-meta">
                <span>{new Date(event.data.date).toLocaleDateString("en-SG", { year: "numeric", month: "short", day: "numeric" })}</span>
                {event.data.time && <span>{formatTime(event.data.time)}</span>}
                {event.data.sponsorName && (
                  <span>
                    sponsored by{" "}
                    {event.data.sponsorUrl ? (
                      <a class="muted-link events-muted-link" href={event.data.sponsorUrl} target="_blank" rel="noopener">{event.data.sponsorName}</a>
                    ) : (
                      event.data.sponsorName
                    )}
                  </span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
