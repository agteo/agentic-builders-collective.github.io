---
interface CalendarEvent {
  id: string;
  title: string;
  startsAt: string;
  endsAt?: string;
  status: string;
  city?: string;
  venue?: string;
  registrationUrl?: string;
  summary?: string;
  hosts: string[];
}

interface Props {
  events: CalendarEvent[];
}

const { events } = Astro.props;
---

<div class="events-calendar" data-calendar-events={JSON.stringify(events)}>
  <div class="calendar-controls">
    <button class="calendar-nav-btn" data-calendar-prev aria-label="Previous month" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M11 13L7 9l4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <span class="calendar-month-label" data-calendar-label></span>
    <button class="calendar-nav-btn" data-calendar-next aria-label="Next month" type="button">
      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <path d="M7 5l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </button>
    <button class="calendar-today-btn" data-calendar-today type="button">Today</button>
  </div>

  <div class="calendar-weekdays">
    <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
  </div>

  <div class="calendar-grid" data-calendar-grid></div>

  <div class="calendar-detail" data-calendar-detail hidden></div>
</div>

<style>
  .events-calendar {
    background: transparent;
    border: 1px dashed var(--line);
    border-radius: 0;
    box-shadow: none;
    padding: 24px;
  }

  .calendar-controls {
    align-items: center;
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
  }

  .calendar-nav-btn {
    align-items: center;
    background: rgba(16, 34, 29, 0.06);
    border: 1px solid var(--line);
    border-radius: 0;
    color: var(--text);
    cursor: pointer;
    display: inline-flex;
    height: 36px;
    justify-content: center;
    transition: background-color 140ms ease, transform 140ms ease;
    width: 36px;
  }

  .calendar-nav-btn:hover {
    background: var(--accent-soft);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .calendar-month-label {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .calendar-today-btn {
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 0;
    color: var(--accent);
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    margin-left: auto;
    padding: 6px 14px;
    transition: background-color 140ms ease, color 140ms ease;
  }

  .calendar-today-btn:hover {
    background: rgba(215, 228, 248, 0.12);
    color: var(--text);
  }

  .calendar-weekdays {
    border-bottom: 1px dashed var(--line);
    color: var(--muted);
    display: grid;
    font-size: 0.8rem;
    font-weight: 600;
    grid-template-columns: repeat(7, 1fr);
    letter-spacing: 0.06em;
    margin-bottom: 4px;
    padding-bottom: 10px;
    text-align: center;
    text-transform: uppercase;
  }

  .calendar-grid {
    display: grid;
    gap: 2px;
    grid-template-columns: repeat(7, 1fr);
  }

  .calendar-grid :global(.calendar-day) {
    align-items: center;
    border-radius: 0;
    display: flex;
    flex-direction: column;
    font-size: 0.92rem;
    gap: 4px;
    justify-content: center;
    min-height: 52px;
    padding: 6px 4px;
    user-select: none;
  }

  .calendar-grid :global(.calendar-day.other-month) {
    color: rgba(16, 34, 29, 0.2);
  }

  .calendar-grid :global(.calendar-day.today) {
    background: var(--accent-soft);
    font-weight: 700;
  }

  .calendar-grid :global(.calendar-day.has-events) {
    background: none;
    border: none;
    color: var(--text);
    cursor: pointer;
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .calendar-grid :global(.calendar-day.has-events.today) {
    background: var(--accent-soft);
  }

  .calendar-grid :global(.calendar-day.has-events:hover) {
    background: rgba(215, 228, 248, 0.12);
  }

  .calendar-grid :global(.calendar-day.has-events:focus-visible) {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  .calendar-grid :global(.calendar-day.selected) {
    background: var(--accent);
    color: white;
  }

  .calendar-grid :global(.calendar-day.selected:hover) {
    background: var(--accent);
  }

  .calendar-grid :global(.event-indicators) {
    display: flex;
    gap: 3px;
  }

  .calendar-grid :global(.event-dot) {
    background: var(--accent);
    border-radius: 0;
    display: block;
    height: 4px;
    width: 4px;
  }

  .calendar-grid :global(.calendar-day.selected .event-dot) {
    background: white;
  }

  .calendar-grid :global(.event-dot.cancelled) {
    background: var(--muted);
  }

  .calendar-detail[hidden] {
    display: none;
  }

  .calendar-detail:not([hidden]) {
    border-top: 1px solid var(--line);
    margin-top: 16px;
    padding-top: 16px;
  }

  .calendar-detail :global(.detail-date) {
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 12px;
    text-transform: uppercase;
  }

  .calendar-detail :global(.detail-event) {
    background: transparent;
    border-left: 3px solid var(--accent);
    border-radius: 0;
    display: grid;
    gap: 6px;
    padding: 14px 16px;
  }

  .calendar-detail :global(.detail-event + .detail-event) {
    margin-top: 10px;
  }

  .calendar-detail :global(.detail-event.status-cancelled) {
    border-left-color: var(--muted);
    opacity: 0.7;
  }

  .calendar-detail :global(.detail-event-title) {
    font-family: var(--font-serif);
    font-size: 1.1rem;
  }

  .calendar-detail :global(.detail-event-meta) {
    color: var(--muted);
    display: flex;
    flex-wrap: wrap;
    font-size: 0.88rem;
    gap: 10px;
  }

  .calendar-detail :global(.status-badge) {
    border: 1px solid var(--line);
    border-radius: 0;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 1px 8px;
    text-transform: uppercase;
  }

  .calendar-detail :global(.status-planned) {
    background: var(--accent-soft);
    color: var(--accent);
  }

  .calendar-detail :global(.status-completed) {
    background: rgba(16, 34, 29, 0.06);
    color: var(--muted);
  }

  .calendar-detail :global(.status-cancelled) {
    background: rgba(180, 60, 60, 0.1);
    color: #b43c3c;
  }

  .calendar-detail :global(.detail-event-summary) {
    color: var(--muted);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .calendar-detail :global(.detail-event-hosts) {
    color: var(--muted);
    font-size: 0.88rem;
    margin: 0;
  }

  @media (max-width: 640px) {
    .events-calendar {
      border-radius: 0;
      padding: 16px;
    }

    .calendar-controls {
      flex-wrap: wrap;
    }

    .calendar-month-label {
      font-size: 1.1rem;
    }

    .calendar-grid :global(.calendar-day) {
      font-size: 0.82rem;
      min-height: 44px;
    }

    .calendar-weekdays {
      font-size: 0.72rem;
    }
  }
</style>

<script>
  const ESC_MAP: Record<string, string> = {
    "&": "&amp;",
    "<": "&lt;",
    ">": "&gt;",
    '"': "&quot;",
    "'": "&#39;",
  };

  function esc(value: string): string {
    return value.replace(/[&<>"']/g, (ch) => ESC_MAP[ch]);
  }

  interface CalendarEvent {
    id: string;
    title: string;
    startsAt: string;
    endsAt?: string;
    status: string;
    city?: string;
    venue?: string;
    registrationUrl?: string;
    summary?: string;
    hosts: string[];
  }

  function dateKey(date: Date): string {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, "0");
    const d = String(date.getDate()).padStart(2, "0");
    return `${y}-${m}-${d}`;
  }

  function initCalendar(root: HTMLElement): void {
    const raw = root.dataset.calendarEvents;
    if (!raw) return;

    const events: CalendarEvent[] = JSON.parse(raw);
    const grid = root.querySelector<HTMLElement>("[data-calendar-grid]")!;
    const label = root.querySelector<HTMLElement>("[data-calendar-label]")!;
    const detail = root.querySelector<HTMLElement>("[data-calendar-detail]")!;

    const today = new Date();
    const todayKey = dateKey(today);
    let viewYear = today.getFullYear();
    let viewMonth = today.getMonth();
    let selectedDate: string | null = null;

    // Build date → events index, supporting multi-day events
    const eventsByDate = new Map<string, CalendarEvent[]>();
    for (const ev of events) {
      const start = new Date(ev.startsAt);
      const end = ev.endsAt ? new Date(ev.endsAt) : start;
      const endK = dateKey(end);
      const cursor = new Date(start.getFullYear(), start.getMonth(), start.getDate());
      let cursorKey = dateKey(cursor);
      let safety = 0;
      while (cursorKey <= endK && safety < 365) {
        if (!eventsByDate.has(cursorKey)) eventsByDate.set(cursorKey, []);
        eventsByDate.get(cursorKey)!.push(ev);
        cursor.setDate(cursor.getDate() + 1);
        cursorKey = dateKey(cursor);
        safety++;
      }
    }

    const monthFmt = new Intl.DateTimeFormat("en-GB", { month: "long", year: "numeric" });
    const dateFmt = new Intl.DateTimeFormat("en-GB", {
      weekday: "long",
      day: "numeric",
      month: "long",
      year: "numeric",
    });
    const timeFmt = new Intl.DateTimeFormat("en-GB", { hour: "2-digit", minute: "2-digit" });

    function renderGrid(): void {
      label.textContent = monthFmt.format(new Date(viewYear, viewMonth, 1));

      const firstDay = new Date(viewYear, viewMonth, 1);
      const lastDay = new Date(viewYear, viewMonth + 1, 0);
      const startDow = (firstDay.getDay() + 6) % 7; // Monday = 0
      const daysInMonth = lastDay.getDate();
      const prevLast = new Date(viewYear, viewMonth, 0).getDate();

      let html = "";

      // Previous-month padding cells
      for (let i = startDow - 1; i >= 0; i--) {
        html += `<span class="calendar-day other-month"><span class="day-number">${prevLast - i}</span></span>`;
      }

      // Current-month day cells
      for (let d = 1; d <= daysInMonth; d++) {
        const key = dateKey(new Date(viewYear, viewMonth, d));
        const dayEvents = eventsByDate.get(key);
        const hasEvents = dayEvents !== undefined && dayEvents.length > 0;
        const isToday = key === todayKey;
        const isSelected = key === selectedDate;

        const classes = ["calendar-day"];
        if (isToday) classes.push("today");
        if (hasEvents) classes.push("has-events");
        if (isSelected) classes.push("selected");

        if (hasEvents) {
          const count = dayEvents!.length;
          const ariaDate = dateFmt.format(new Date(viewYear, viewMonth, d));
          const ariaLabel = `${ariaDate}, ${count} event${count > 1 ? "s" : ""}`;
          const dots = dayEvents!
            .map(
              (e) =>
                `<span class="event-dot${e.status === "cancelled" ? " cancelled" : ""}"></span>`
            )
            .join("");
          html += `<button class="${classes.join(" ")}" data-date="${key}" type="button" aria-label="${esc(ariaLabel)}"><span class="day-number">${d}</span><span class="event-indicators">${dots}</span></button>`;
        } else {
          html += `<span class="${classes.join(" ")}"><span class="day-number">${d}</span></span>`;
        }
      }

      // Next-month padding cells
      const totalCells = startDow + daysInMonth;
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let d = 1; d <= remaining; d++) {
        html += `<span class="calendar-day other-month"><span class="day-number">${d}</span></span>`;
      }

      grid.innerHTML = html;

      for (const btn of grid.querySelectorAll<HTMLButtonElement>(".has-events")) {
        btn.addEventListener("click", () => {
          const clickedKey = btn.dataset.date!;
          selectedDate = selectedDate === clickedKey ? null : clickedKey;
          renderGrid();
        });
      }

      renderDetail();
    }

    function renderDetail(): void {
      if (!selectedDate || !eventsByDate.has(selectedDate)) {
        detail.hidden = true;
        return;
      }

      const dayEvents = eventsByDate.get(selectedDate)!;
      const dateLabel = dateFmt.format(new Date(selectedDate + "T00:00:00"));

      let html = `<div class="detail-date">${esc(dateLabel)}</div>`;

      for (const ev of dayEvents) {
        const time = timeFmt.format(new Date(ev.startsAt));
        const cls = ev.status === "cancelled" ? " status-cancelled" : "";

        html += `<div class="detail-event${cls}">`;
        html += `<strong class="detail-event-title">${esc(ev.title)}</strong>`;
        html += `<div class="detail-event-meta">`;
        html += `<span>${esc(time)}</span>`;
        if (ev.city) html += `<span>${esc(ev.city)}</span>`;
        if (ev.venue) html += `<span>${esc(ev.venue)}</span>`;
        html += `<span class="status-badge status-${esc(ev.status)}">${esc(ev.status)}</span>`;
        html += `</div>`;
        if (ev.summary) html += `<p class="detail-event-summary">${esc(ev.summary)}</p>`;
        if (ev.hosts.length > 0)
          html += `<p class="detail-event-hosts">Hosted by ${esc(ev.hosts.join(", "))}</p>`;
        if (ev.registrationUrl)
          html += `<a class="muted-link" href="${esc(ev.registrationUrl)}" target="_blank" rel="noreferrer">Register →</a>`;
        html += `</div>`;
      }

      detail.hidden = false;
      detail.innerHTML = html;
    }

    root.querySelector("[data-calendar-prev]")!.addEventListener("click", () => {
      viewMonth--;
      if (viewMonth < 0) {
        viewMonth = 11;
        viewYear--;
      }
      selectedDate = null;
      renderGrid();
    });

    root.querySelector("[data-calendar-next]")!.addEventListener("click", () => {
      viewMonth++;
      if (viewMonth > 11) {
        viewMonth = 0;
        viewYear++;
      }
      selectedDate = null;
      renderGrid();
    });

    root.querySelector("[data-calendar-today]")!.addEventListener("click", () => {
      viewYear = today.getFullYear();
      viewMonth = today.getMonth();
      selectedDate = null;
      renderGrid();
    });

    renderGrid();
  }

  document.querySelectorAll<HTMLElement>(".events-calendar").forEach(initCalendar);
</script>
