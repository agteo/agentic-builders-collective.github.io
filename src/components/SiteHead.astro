---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
}

const siteName = "Agentic Builders Collective";
const defaultDescription =
  "A Singapore community for developers and builders exploring agentic coding with AI tools, meetups, shared projects, and open resources.";

const {
  title,
  description = defaultDescription,
  image = "/og-image.png",
  type = "website",
} = Astro.props;

const trimmedTitle = title?.trim();
const fullTitle = trimmedTitle ? `${trimmedTitle} | ${siteName}` : siteName;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const imageUrl = new URL(image, Astro.site ?? Astro.url).toString();
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index,follow" />
<meta name="theme-color" content="#0A0D1C" />
<meta name="application-name" content={siteName} />
<meta name="apple-mobile-web-app-title" content="ABC" />
<meta name="mobile-web-app-capable" content="yes" />
<link rel="icon" href="/favicon.ico" type="image/x-icon" />
<link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
<link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
<meta property="og:locale" content="en_GB" />
<meta property="og:type" content={type} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={siteName} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:image:alt" content={siteName} />
