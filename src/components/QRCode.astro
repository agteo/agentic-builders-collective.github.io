---
export interface Props {
  url: string;
  size?: number;
}

const { url, size = 200 } = Astro.props;

import QRCodeLib from 'qrcode';

let dataUrl = '';
try {
  dataUrl = await QRCodeLib.toDataURL(url, {
    width: size,
    margin: 2,
    color: {
      dark: '#d9e7ff',
      light: '#00000000',
    },
  });
} catch (err) {
  console.error('QR Code generation failed:', err);
}
---

{dataUrl && (
  <div class="qr-container">
    <img 
      src={dataUrl} 
      alt="QR Code" 
      class="qr-code"
      width={size}
      height={size}
    />
    <style>
      .qr-container {
        display: inline-block;
        padding: 16px;
        background: black;
      }
      .qr-code {
        display: block;
      }
    </style>
  </div>
)}
